model User { 
  id    Int     @id @default(autoincrement()) 
  name  String
  email String  @unique
  password  String
  image  String // image path as string
  isVerifyed  Boolean @default(false)
  refreshTokens  RefreshToken?
  profession String
  gender Gender
  role Role @default(User)
  following Follower[] @relation("UserFollows")
  followers Follower[] @relation("UserFollowed")
  feeds Feed[] 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts Post[]
  comments Comment[]
  likes Likes[]
  savePosts SavePost[]
  @@map("user")
} 
enum Gender {
  Male
  Female
  Others
}
enum Role {
  User
  Admin
}
